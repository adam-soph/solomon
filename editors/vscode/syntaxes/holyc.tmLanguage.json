{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HolyC",
  "scopeName": "source.holyc",
  "fileTypes": ["hc", "HC"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.holyc",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.holyc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.holyc",
          "match": "^\\s*(#\\s*include)\\b\\s*(\"[^\"]*\")?",
          "captures": {
            "1": { "name": "keyword.control.directive.include.holyc" },
            "2": { "name": "string.quoted.double.include.holyc" }
          }
        },
        {
          "name": "meta.preprocessor.holyc",
          "match": "^\\s*(#\\s*(?:define|undef|ifdef|ifndef|else|endif|if|elif|error|pragma))\\b",
          "captures": {
            "1": { "name": "keyword.control.directive.holyc" }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.holyc",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "include": "#string-escapes" }]
    },
    "chars": {
      "name": "string.quoted.single.holyc",
      "begin": "'",
      "end": "'",
      "patterns": [{ "include": "#string-escapes" }]
    },
    "string-escapes": {
      "name": "constant.character.escape.holyc",
      "match": "\\\\(?:[abfnrtv0\\\\\"'?]|x[0-9A-Fa-f]{1,2}|[0-7]{1,3})"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.holyc",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.holyc",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.float.holyc",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b|\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.holyc",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.holyc",
          "match": "\\b(if|else|while|do|for|switch|case|default|break|continue|return|goto|try|catch|throw|start|end)\\b"
        },
        {
          "name": "keyword.other.holyc",
          "match": "\\b(class|union|typedef|public|extern|import|reg|noreg|lastclass|sizeof|offset|no_warn|asm)\\b"
        }
      ]
    },
    "types": {
      "name": "storage.type.holyc",
      "match": "\\b(U0|I8|U8|I16|U16|I32|U32|I64|U64|F64|Bool)\\b"
    },
    "constants": {
      "name": "constant.language.holyc",
      "match": "\\b(NULL|TRUE|FALSE)\\b"
    },
    "builtins": {
      "name": "support.function.builtin.holyc",
      "match": "\\b(Print|StrPrint|CatPrint|MStrPrint|Str2I64|Abs|Sqrt|StrLen|StrCmp|StrCpy|MAlloc|Free|StrCat|MemCpy|MemSet|ToUpper|ToLower|Sin|Cos|Pow|MemCmp|Floor|Ceil|Round|Exp|Ln|Tan|StrFind|ASin|ACos|ATan|ATan2|Log10|StrNCmp|StrNCpy|Fabs|Sign|RandU64)\\b"
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.holyc" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.holyc",
          "match": "(<<=|>>=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|=)"
        },
        {
          "name": "keyword.operator.comparison.holyc",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.holyc",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.holyc",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.arithmetic.holyc",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.access.holyc",
          "match": "(->|\\.\\.\\.|::|\\.|\\?|:)"
        }
      ]
    }
  }
}
